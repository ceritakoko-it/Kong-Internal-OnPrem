# Dev Portal OpenAPI generation values.
#
# This file is intentionally consumed only by pipelines/dev-portal.yml.
# Keep real credentials, real tokens, NRIC, customer data, and production keys out of this file.
#
# Request body keys use this format:
# DP_REQUEST_BODY_<METHOD>_<PUBLIC_PATH>
#
# The public path is uppercased and non-alphanumeric characters become underscores.
# Example:
#   POST /api/token -> DP_REQUEST_BODY_POST_API_TOKEN
#
# If a request body key is missing or blank, the generated OpenAPI operation has no predefined request body.
#
# Extra header keys use this format:
# DP_EXTRA_HEADERS_<METHOD>_<PUBLIC_PATH>=Header-One,Header-Two
#
# Query parameter keys use this format:
# DP_QUERY_PARAMS_<METHOD>_<PUBLIC_PATH>=requiredParam*,optionalParam

DEVPORTAL_TITLE=Kong Konnect Internal APIs (Dev On-Prem)
DEVPORTAL_SERVER_URL=https://kong-api-dev.takaful-malaysia.com.my:443
DEVPORTAL_SERVER_DESCRIPTION=Internal Takaful API Dev Server
DEVPORTAL_DESCRIPTION=Takaful internal services exposed through Kong Gateway. Call /api/token first to obtain an access token, then reuse Authorization: Bearer <access_token> for protected APIs. Service-specific headers such as apikey, X-Auth-Token, or X-API-KEY are required only for selected flows.

DP_REQUEST_BODY_POST_API_TOKEN={"grant_type":"client_credentials","client_id":"your-client-id","client_secret":"your-client-secret"}
DP_CONTENT_TYPE_POST_API_TOKEN=application/x-www-form-urlencoded

DP_REQUEST_BODY_POST_API_WSMANAGER_KYCINPUT_ADD={"messageId":"<message-id>","partitionId":"0","message":"<xml-string-payload>"}
DP_EXTRA_HEADERS_POST_API_WSMANAGER_KYCINPUT_ADD=apikey

DP_EXTRA_HEADERS_GET_API_WSMANAGER_KYCTOPIC_GET=apikey
DP_QUERY_PARAMS_GET_API_WSMANAGER_KYCTOPIC_GET=topic*,clientId*,groupId*,count

DP_EXTRA_HEADERS_GET_API_WSMANAGER_KYC_RISKSCORE_GETLATEST=apikey
DP_QUERY_PARAMS_GET_API_WSMANAGER_KYC_RISKSCORE_GETLATEST=clientKey*,zoneId*

DP_REQUEST_BODY_POST_AML_RESTSVC_SCAN={"Client_Name":"<client-name>","Client_DOB":"","Client_ID_Type":"NRIC","Client_ID_No":"<client-id-no>","Client_Gender":"","Client_Nationality":"","Source_System":"DTM","Transaction_Type":"NB","Department_Code":"FUCS","Transaction_Ref_No":"<transaction-ref-no>","Transaction_Ref_No_2":"","Transaction_Date":"YYYY-MM-DD","Name01":"","Name02":"","Name03":"","Name04":"","Name05":"","Name06":"","Name07":"","Name08":"","Name09":"","Name10":"","Name11":"","Name12":"","Name13":"","Name14":"","Name15":""}

DP_REQUEST_BODY_POST_AML_RESTSVC_AB_SCAN={"Client_Name":"<client-name>","Client_DOB":"","Client_ID_Type":"NRIC","Client_ID_No":"<client-id-no>","Client_Gender":"","Client_Nationality":"","Source_System":"DTM","Transaction_Type":"NB","Department_Code":"FUCS","Transaction_Ref_No":"<transaction-ref-no>","Transaction_Ref_No_2":"","Transaction_Date":"YYYY-MM-DD","Name01":"","Name02":"","Name03":"","Name04":"","Name05":"","Name06":"","Name07":"","Name08":"","Name09":"","Name10":"","Name11":"","Name12":"","Name13":"","Name14":"","Name15":""}

DP_REQUEST_BODY_POST_AUTH_BANCA_LOGIN={"UserName":"<username>","Password":"<password>"}

DP_CONTENT_TYPE_POST_AUTH_BANCA_AUTHENTICATE=application/xml
DP_REQUEST_BODY_POST_AUTH_BANCA_AUTHENTICATE<<EOF
<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<authentication>
  <body>
    <apiKey>&lt;banca-api-key&gt;</apiKey>
    <apiSecret>&lt;banca-api-secret&gt;</apiSecret>
  </body>
</authentication>
EOF

DP_CONTENT_TYPE_POST_AUTH_BANCA_LOGOUT=application/json
DP_REQUEST_BODY_POST_AUTH_BANCA_LOGOUT={"SessionID":"<session-id>"}

DP_CONTENT_TYPE_POST_API_BANCA_CALCULATE=application/xml
DP_EXTRA_HEADERS_POST_API_BANCA_CALCULATE=X-Auth-Token
DP_REQUEST_BODY_POST_API_BANCA_CALCULATE<<EOF
<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<calculate>
  <body>
    <nationality>Malaysian</nationality>
    <dob>YYYYMMDD</dob>
    <gender>Male</gender>
    <paymentbasis>N</paymentbasis>
    <plantype>BLTT</plantype>
    <schemename>01</schemename>
    <fr1>0.00</fr1>
    <fr2>INCLUSIVE</fr2>
    <fr3>1</fr3>
    <amount>1500000</amount>
    <interim>0</interim>
  </body>
</calculate>
EOF

DP_CONTENT_TYPE_POST_API_BANCA_QUOTATION=application/xml
DP_EXTRA_HEADERS_POST_API_BANCA_QUOTATION=X-Auth-Token
DP_REQUEST_BODY_POST_API_BANCA_QUOTATION<<EOF
<?xml version="1.0" encoding="UTF-8"?>
<equotation>
  <body>
    <pfeid>&lt;pfeid&gt;</pfeid>
    <name>&lt;name&gt;</name>
    <nationality>Malaysian</nationality>
    <mykad>&lt;masked-id&gt;</mykad>
    <dob>YYYYMMDD</dob>
    <gender>Female</gender>
    <paymentbasis>G</paymentbasis>
    <plantype>MLTT</plantype>
    <schemename>01</schemename>
    <amount>10000</amount>
    <email>user@example.com</email>
    <mobile>&lt;mobile&gt;</mobile>
  </body>
</equotation>
EOF

DP_REQUEST_BODY_POST_API_STORM_ACCOUNT={"userNric":"<nric>","userEmail":"user@example.com","userName":"<username>","userMobile":"<mobile>","userDob":"DD/MM/YYYY","userNricType":"NEW"}
DP_EXTRA_HEADERS_POST_API_STORM_ACCOUNT=X-API-KEY

DP_REQUEST_BODY_POST_API_STORM_VELOGICA={"nric":"<nric>","productCode":"<product-code>"}
DP_EXTRA_HEADERS_POST_API_STORM_VELOGICA=X-API-KEY
